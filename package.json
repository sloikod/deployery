{
  "name": "deployery",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:api": "turbo run dev --filter=@deployery/api",
    "build": "turbo run build",
    "build:docker": "docker compose build",
    "up": "docker compose up --build",
    "up:clean": "docker compose down -v && docker compose up --build",
    "down": "docker compose down",
    "down:clean": "docker compose down -v",
    "check": "pnpm lint && pnpm check-types && pnpm test:run",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:run": "vitest run --coverage",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,yml,yaml}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.1"
  }
}
