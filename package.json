{
	"name": "deployery",
	"version": "1.0.0-beta",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"check": "turbo run check lint && eslint . --cache && node scripts/formatting.mjs -n && node scripts/llm.mjs -n && node scripts/periods.mjs -n && vitest run",
		"check:formatting": "node scripts/formatting.mjs -n",
		"check:llm": "node scripts/llm.mjs -n",
		"check:periods": "node scripts/periods.mjs -n",
		"check:prettier": "node scripts/formatting.mjs -n",
		"format": "node scripts/llm.mjs -y && node scripts/periods.mjs -y && node scripts/formatting.mjs -y",
		"format:formatting": "node scripts/formatting.mjs -y",
		"format:llm": "node scripts/llm.mjs -y",
		"format:periods": "node scripts/periods.mjs -y",
		"format:prettier": "node scripts/formatting.mjs -y"
	},
	"prettier": {
		"singleQuote": true,
		"printWidth": 100,
		"useTabs": true
	},
	"devDependencies": {
		"@deployery/configs": "workspace:*",
		"@deployery/constants": "workspace:*",
		"@vitest/coverage-v8": "^4.1.2",
		"eslint": "^10.2.0",
		"prettier": "^3.8.1",
		"turbo": "^2.9.3",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
