{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "out/**", ".next/**"]
		},
		"check": {
			"dependsOn": ["^check"],
			"outputs": []
		},
		"lint": {
			"dependsOn": ["^lint"],
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"@deployery/docker#build": {
			"cache": false
		}
	}
}
