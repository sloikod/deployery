{
  "name": "@deployery/persistence",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings 0",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests --config ../../vitest.config.ts",
    "test:unit": "vitest run --passWithNoTests --config ../../vitest.config.ts",
    "test:integration": "vitest run --passWithNoTests --config ../../vitest.integration.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts"
  },
  "dependencies": {
    "@deployery/workflow-schema": "workspace:*",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.44.7",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.6",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  }
}
