{
  "name": "@deployery/cli",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Interactive CLI for Deployery workflows",
  "bin": {
    "deployery": "dist/main.js"
  },
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings 0",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests --config ../../vitest.config.ts",
    "test:unit": "vitest run --passWithNoTests --config ../../vitest.config.ts",
    "test:integration": "vitest run --passWithNoTests --config ../../vitest.integration.config.ts"
  },
  "dependencies": {
    "@deployery/workflow-schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  }
}
